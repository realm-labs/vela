fn main(player: Player, scores: IntIntMap, tags: TagSet, rewards: RewardSink) {
    scores.set(1001, 5);
    scores.add_to(1001, 2);

    if scores.contains(1001) && tags.contains("vip") {
        let amount = scores.get(1001);
        player.inventory.items["gold"].count += amount;
        rewards.grant("gold", amount);
        rewards.grant("badge", 1);
        player.reward_sink.grant("quest", 1);
    }

    return player.inventory.items["gold"].count;
}
