fn main(ctx, player, monster) {
    player.exp += monster.exp;

    if player.exp >= 100 {
        player.level += 1;
        player.exp = 0;
        ctx.emit("player.level_up", player.level);
    }

    player.inventory.items["gold"].count += monster.reward_count;
    ctx.emit("monster.kill", monster.id, player.level);
    return player.level;
}
