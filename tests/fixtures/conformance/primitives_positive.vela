struct Cell {
    value: i64,
}

fn expect_i64(value: i64) {
    return value;
}

fn expect_f64(value: f64) {
    return value;
}

fn expect_i8(value: i8) {
    return value;
}

fn dynamic_to_i64(value) {
    return expect_i64(value);
}

fn assign_cell(cell: Cell, value) {
    cell.value = value;
    return cell.value;
}

fn inc(value) {
    return value + 1;
}

fn main() {
    let default_integer = 12;
    let default_float = 2.5;
    let contextual: i8 = 7;
    let min_i8: i8 = -128i8;
    let min_i64: i64 = -9223372036854775808i64;
    let data = b"\x01\x02\x03\x04";

    let literal_score: i64 = if expect_i64(default_integer) == 12
        && expect_f64(default_float) == 2.5f64
        && expect_i8(contextual) == 7i8
        && min_i8 == -128i8
        && min_i64 == -9223372036854775808i64
    {
        19
    } else {
        0
    };

    let deferred_score: i64 = if inc(1i8) == 2i8
        && inc(1u32) == 2u32
        && inc(1) == 2
    {
        13
    } else {
        0
    };

    let cell: Cell = Cell { value: 1 };
    let guard_score: i64 = if dynamic_to_i64(default_integer) == 12
        && assign_cell(cell, 9) == 9
    {
        17
    } else {
        0
    };

    let bytes_score: i64 = if data[0] == 1u8
        && data.read_u32_le(0) == 0x04030201u32
        && data.read_u32_be(0) == 0x01020304u32
    {
        11
    } else {
        0
    };

    return literal_score + deferred_score + guard_score + bytes_score;
}
