pub const BASE_REWARD = 4
pub const REWARD_COUNTS = [BASE_REWARD, BASE_REWARD + 1]
pub const REWARD_TABLE = {"gold": BASE_REWARD, "gem": BASE_REWARD + 2}

pub struct RewardConfig {
    item: string,
    count: int = BASE_REWARD,
}

pub enum RewardOutcome {
    Granted { item: string, count: int },
    Skipped(string),
}

pub fn reward_bonus(amount, scale = 2) {
    return amount * scale + BASE_REWARD;
}
