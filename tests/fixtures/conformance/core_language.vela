#!/usr/bin/env vela
/* Grammar conformance: nested block comments must be layout.
   The inner comment deliberately contains item-like text:
   /* fn hidden() { return 999; } */
*/
use conformance::reward::BASE_REWARD as REWARD_BASE
use conformance::reward::REWARD_COUNTS
use conformance::reward::REWARD_TABLE
use conformance::reward::RewardConfig as ConfigReward
use conformance::reward::RewardOutcome as Outcome
use conformance::reward::reward_bonus

const BASE = 2

#[doc("Core reward")]
#[domain("conformance")]
#[rule(kind = conformance::reward::Rule, tags = ["core", "fixture"], config = { enabled: true, limit: 3 })]
struct Reward {
    #[doc("Reward item")]
    item: String,
    count: i64,
}

struct Stats {
    level: i64,
    exp: i64,
}

struct Player {
    stats: Stats,
}

enum QuestState {
    Active { id: String, count: i64 },
    #[terminal]
    Done { id: String },
    Streak(kind: String = "weekly", count: i64),
}

#[doc("Scored contract")]
trait Scored {
    #[doc("Score reward")]
    fn score(self) -> i64;
    fn weighted(self, amount: i64, multiplier: i64 = 2, offset: i64 = BASE) -> i64;
}

impl Scored for Reward {
    fn score(self) -> i64 {
        return self.count + BASE;
    }

    fn weighted(self, amount: i64, multiplier: i64 = 2, offset: i64 = BASE) -> i64 {
        return self.count + amount * multiplier + offset;
    }
}

fn maybe_bonus(flag) {
    if flag {
        return option::some(3);
    }
    return option::none();
}

fn result_bonus(flag) {
    let bonus = maybe_bonus(flag)?;
    return result::ok(bonus + 1);
}

fn add(base, amount = 1, bonus = amount + BASE) {
    return base + amount + bonus;
}

#[doc("Core conformance entry")]
fn main() {
    let reward: Reward = Reward { item: "gold", count: 5 };
    /* Nested comments inside executable bodies must not affect lowering:
       /* let impossible = missing_symbol; */
    */
    #[trace("values")]
    let values: Array = [1, 2, 3, 4, 5];
    let total: i64 = 0;
    #[audit]
    for value in values {
        if value == 2 {
            continue;
        }
        if value > 4 {
            break;
        }
        total += value;
    }
    let compound_score: i64 = 20;
    compound_score -= 3;
    compound_score *= 2;
    compound_score /= 4;
    compound_score %= 5;
    let logical_score: i64 = {
        let short_or = if true || (1 / 0 == 0) { 4 } else { 0 };
        let short_and = if false && (1 / 0 == 0) { 0 } else { 6 };
        let negated = -BASE + 5;
        if !false {
            short_or + short_and + negated
        } else {
            0
        }
    };

    let doubled: i64 = values
        .filter(|value| value % 2 == 1)
        .map(|value| value * 2)
        .sum();
    let helper_values: Array = [21, 11, 10, 12, 13];
    let groups: Map = helper_values.group_by(|value| if value % 2 == 0 {
        "even"
    } else {
        "odd"
    });
    let sorted: Array = helper_values.sort_by(|value| value % 10);
    let found = helper_values.find(|value| value == 12);
    let helper_slice: Array = sorted.slice(1, 4);
    let reversed: Array = helper_slice.reverse();
    let unique: Array = [1, 2, 1, 3, 2].distinct();
    let array_helper_score: i64 = if groups["odd"].count(|value| value > 12) == 2
        && groups["even"].sum() == 22
        && sorted[0] == 10
        && sorted[2] == 11
        && option::unwrap_or(found, 0) == 12
        && helper_values.any(|value| value > 20)
        && helper_values.all(|value| value >= 10)
        && helper_values.count(|value| value % 2 == 1) == 3
        && option::unwrap_or(helper_values.first(), 0) == 21
        && option::unwrap_or(helper_values.last(), 0) == 13
        && option::unwrap_or(helper_values.min(), 0) == 10
        && option::unwrap_or(helper_values.max(), 0) == 21
        && option::unwrap_or(helper_values.index_of(12), -1) == 3
        && reversed[0] == 12
        && unique.len() == 3
    {
        25
    } else {
        0
    };
    let mutable_values: Array = [10, 30];
    mutable_values.insert(1, 20);
    mutable_values.push(50);
    let popped_value = mutable_values.pop();
    mutable_values.extend([40, 60]);
    let removed_value = mutable_values.remove_at(0);
    let missing_remove = mutable_values.remove_at(99);
    let array_mutation_score: i64 = if popped_value.unwrap_or(0) == 50
        && removed_value.unwrap_or(0) == 10
        && missing_remove.is_none()
        && mutable_values.len() == 4
        && mutable_values[0] == 20
        && mutable_values[1] == 30
        && mutable_values[2] == 40
        && mutable_values[3] == 60
    {
        mutable_values.clear();
        mutable_values.push(70);
        if mutable_values.len() == 1 && mutable_values[0] == 70 {
            60
        } else {
            0
        }
    } else {
        0
    };

    let quest: QuestState = QuestState::Active { id: "daily", count: 2 };
    let quest_score: i64 = match quest {
        QuestState::Active { id, count } if id == "daily" => count + 10,
        QuestState::Done { id } => id.len(),
        _ => 0,
    };
    let streak: QuestState = QuestState::Streak(count = 4);
    let streak_score: i64 = match streak {
        QuestState::Streak(kind, count) if kind == "weekly" => count * 3,
        _ => 0,
    };

    let block_value: i64 = {
        let local = add(bonus = 3, base = 4);
        local + reward.score()
    };
    let named_method_score: i64 = reward.weighted(offset = 4, amount = 3);
    let nested_lambda_score: i64 = {
        let make_nested = |base| {
            return |amount| {
                return |bonus| base + amount + bonus;
            };
        };
        let make = make_nested(8);
        let add = make(4);
        add(2)
    };
    let zero_arg_lambda_score: i64 = {
        let captured_bonus = || {
            return reward.count + 9;
        };
        captured_bonus()
    };

    let parsed: i64 = "42".parse_i64().unwrap_or(0);
    let normalized = "  Quest.Reward Done  ".trim().replace(" ", "_").to_lower();
    let pieces = normalized.split(".");
    let prefix = normalized.strip_prefix("quest.");
    let suffix = normalized.strip_suffix("_done");
    let pair = "count=3".split_once("=").unwrap_or(["", "0"]);
    let words = " grant\tgold 3 ".split_whitespace();
    let lines = "start\napply\ncommit".split_lines();
    let reward_char = '\0';
    let reward_char_index = 0;
    for ch in "xp奖励" {
        if reward_char_index == 2 {
            reward_char = ch;
        }
        reward_char_index += 1;
    }
    let string_helper_score: i64 = if normalized.starts_with("quest")
        && normalized.ends_with("_done")
        && normalized.contains("reward")
        && option::unwrap_or(normalized.find("reward"), -1) == 6
        && pieces[0] == "quest"
        && option::unwrap_or(option::unwrap_or(prefix, "").strip_suffix("_done"), "") == "reward"
        && option::unwrap_or(suffix, "") == "quest.reward"
        && pair[0] == "count"
        && pair[1].parse_i64().unwrap_or(0) == 3
        && words.join(".") == "grant.gold.3"
        && lines[1] == "apply"
        && option::unwrap_or("true".parse_bool(), false)
        && option::unwrap_or("2.5".parse_f64(), 0.0) == 2.5
        && reward_char == '奖'
        && "xp奖励".slice(2, 8) == "奖励"
    {
        30
    } else {
        0
    };
    let padded_label = "\tQuest.Log  ";
    let string_utility_score: i64 = if padded_label.trim_start().trim_end() == "Quest.Log"
        && "wolf".to_upper() == "WOLF"
        && "xp".repeat(3) == "xpxpxp"
        && "quest".repeat(0) == ""
    {
        15
    } else {
        0
    };
    let math_helper_score: i64 = if math::max(4, 9) == 9
        && math::min(4, 9) == 4
        && math::clamp(15, 1, 10) == 10
        && math::lerp(10, 20, 0.5) == 15.0
        && math::move_towards(0, 10, 4) == 4
        && math::distance2d(0, 0, 3, 4) == 5.0
        && math::distance3d(0, 0, 0, 2, 3, 6) == 7.0
        && math::pow(2, 3) == 8
        && math::sqrt(81) == 9.0
        && math::sign(-2) == -1
        && math::floor(2.9) == 2
        && math::ceil(2.1) == 3
        && math::round(2.5) == 3
        && math::abs(-7) == 7
    {
        35
    } else {
        0
    };
    let option_chain = option::some("quest")
        .map(|value| value.to_upper())
        .filter(|value| value.starts_with("Q"))
        .ok_or("missing");
    let option_fallback = option::none().or_else(| | option::some("fallback"));
    let result_chain = result::ok(["gold", "xp"])
        .map(|values| values.join("+"))
        .and_then(|text| result::ok(text.replace("+", ".")));
    let mapped_err = result::err(["bad", "level"]).map_err(|errors| errors.join("."));
    let flattened_option = option::some(option::some(["daily", "done"])).flatten();
    let flattened_result = result::ok(result::err("nested")).flatten();
    let option_result_helper_score: i64 = if option_chain.unwrap_or("") == "QUEST"
        && option_fallback.unwrap_or("") == "fallback"
        && result_chain.unwrap_or("") == "gold.xp"
        && mapped_err.to_error_option().unwrap_or("") == "bad.level"
        && flattened_option.unwrap_or([]).join(".") == "daily.done"
        && flattened_result.to_error_option().unwrap_or("") == "nested"
    {
        45
    } else {
        0
    };
    let result: i64 = result_bonus(true)?;
    let mapped: Map = {"gold": reward.count, "quest": quest_score}
        .map_values(|key, value| key.len() + value);
    let mutable_rewards: Map = {"gold": 1, "xp": 2};
    mutable_rewards.set("quest", 4);
    let removed_reward = mutable_rewards.remove("xp");
    let merged_rewards: Map = mutable_rewards.merge({"gold": 5, "gem": 6});
    let map_score: i64 = option::unwrap_or(removed_reward, 0)
        + mutable_rewards.get_or("missing", 7)
        + merged_rewards["gold"]
        + merged_rewards["gem"]
        + merged_rewards.len();
    let reward_entries = merged_rewards.entries().collect_array();
    let reward_keys = merged_rewards.keys().collect_array();
    let reward_values = merged_rewards.values().collect_array();
    let found_reward = merged_rewards.find(|key, value| key == "gem" && value == 6);
    let found_entry = found_reward.unwrap_or(MapEntry { key: "", value: 0 });
    let filtered_rewards = merged_rewards.filter(|key, value| key.len() >= 3 && value >= 5);
    let mutable_map: Map = {"daily": "open"};
    mutable_map.extend({"raid": "active", "daily": "done"});
    let map_helper_score: i64 = if reward_keys.join(",") == "gem,gold,quest"
        && reward_values.sum() == 15
        && reward_entries[0].key == "gem"
        && reward_entries[0].value == 6
        && found_entry.key == "gem"
        && found_entry.value == 6
        && filtered_rewards.len() == 2
        && merged_rewards.any(|value| value == 6)
        && merged_rewards.all(|key, value| key.len() >= 3 && value > 0)
        && merged_rewards.count(|key, value| value >= 5) == 2
        && mutable_map["daily"] == "done"
        && mutable_map["raid"] == "active"
    {
        mutable_map.clear();
        mutable_map.set("boss", "ready");
        if mutable_map.len() == 1 && mutable_map["boss"] == "ready" {
            50
        } else {
            0
        }
    } else {
        0
    };
    let player_tags: Set = set::from_array(["daily", "quest", "raid"]);
    let event_tags: Set = set::from_array(["quest", "bonus", "daily"]);
    let required_tags: Set = set::from_array(["daily", "quest"]);
    let set_score: i64 = {
        let shared = player_tags.intersection(event_tags);
        let unique = player_tags.difference(event_tags);
        if required_tags.is_subset(player_tags)
            && player_tags.is_superset(required_tags)
            && player_tags.is_disjoint(set::from_array(["bonus"]))
            && player_tags.union(event_tags).len() == 4
            && player_tags.symmetric_difference(event_tags).len() == 2
            && shared.has("quest")
            && unique.has("raid")
        {
            shared.len() + unique.len()
        } else {
            0
        }
    };
    let mutable_tags: Set = set::from_array(["daily", "quest"]);
    let added_tag = mutable_tags.add("raid");
    let duplicate_tag = mutable_tags.add("quest");
    let removed_tag = mutable_tags.remove("daily");
    mutable_tags.extend(set::from_array(["boss", "quest"]));
    let filtered_tags = mutable_tags.filter(|tag| tag.contains("s"));
    let mapped_lengths = mutable_tags.map(|tag| tag.len());
    let found_tag = mutable_tags.find(|tag| tag.starts_with("r"));
    let set_helper_score: i64 = if added_tag
        && !duplicate_tag
        && removed_tag
        && !mutable_tags.has("daily")
        && mutable_tags.any(|tag| tag == "boss")
        && mutable_tags.all(|tag| tag.len() >= 4)
        && mutable_tags.count(|tag| tag.contains("s")) == 2
        && filtered_tags.len() == 2
        && found_tag.unwrap_or("") == "raid"
        && mapped_lengths.has(4)
        && mapped_lengths.has(5)
    {
        mutable_tags.clear();
        mutable_tags.add("done");
        if mutable_tags.len() == 1 && mutable_tags.has("done") {
            55
        } else {
            0
        }
    } else {
        0
    };
    let player: Player = Player {
        stats: Stats {
            level: 2,
            exp: 5,
        },
    };
    player.stats.level += 3;
    player.stats.exp = player.stats.level + 1;
    let nested_score: i64 = player.stats.level + player.stats.exp;
    let players: Array = [
        Player {
            stats: Stats {
                level: 2,
                exp: 0,
            },
        },
        Player {
            stats: Stats {
                level: 5,
                exp: 1,
            },
        },
    ];
    players[0].stats.level += 4;
    players[1].stats.exp = players[0].stats.level + 3;
    let indexed_record_score: i64 = players[0].stats.level + players[1].stats.exp;
    let no_else_score: i64 = {
        let maybe = if false {
            9;
        };
        if maybe == null { 6 } else { 0 }
    };
    let imported_reward: ConfigReward = ConfigReward { item: "gem" };
    let imported_bonus: i64 = reward_bonus(imported_reward.count) + REWARD_BASE;
    let outcome: Outcome = Outcome::Granted {
        item: imported_reward.item,
        count: imported_reward.count,
    };
    let imported_match: i64 = match outcome {
        Outcome::Granted { item, count } if item == "gem" => count + 5,
        Outcome::Skipped(reason) => reason.len(),
        _ => 0,
    };
    let imported_counts: Array = REWARD_COUNTS;
    let imported_table: Map = REWARD_TABLE;
    let imported_const_score: i64 = imported_counts.sum() + imported_table["gem"];

    return total
        + compound_score
        + logical_score
        + doubled
        + array_helper_score
        + array_mutation_score
        + quest_score
        + streak_score
        + block_value
        + named_method_score
        + nested_lambda_score
        + zero_arg_lambda_score
        + parsed
        + string_helper_score
        + string_utility_score
        + math_helper_score
        + option_result_helper_score
        + result
        + mapped["gold"]
        + mapped["quest"]
        + map_score
        + map_helper_score
        + set_score
        + set_helper_score
        + nested_score
        + indexed_record_score
        + no_else_score
        + imported_bonus
        + imported_match
        + imported_const_score;
}
