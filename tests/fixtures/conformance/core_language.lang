#!/usr/bin/env vela
/* Grammar conformance: nested block comments must be layout.
   The inner comment deliberately contains item-like text:
   /* fn hidden() { return 999; } */
*/
use conformance.reward.BASE_REWARD as REWARD_BASE
use conformance.reward.REWARD_COUNTS
use conformance.reward.REWARD_TABLE
use conformance.reward.RewardConfig as ConfigReward
use conformance.reward.RewardOutcome as Outcome
use conformance.reward.reward_bonus

const BASE = 2

#[doc("Core reward")]
#[domain("conformance")]
#[rule(kind = conformance.reward.Rule, tags = ["core", "fixture"], config = { enabled: true, limit: 3 })]
struct Reward {
    #[doc("Reward item")]
    item: string,
    count: int,
}

struct Stats {
    level: int,
    exp: int,
}

struct Player {
    stats: Stats,
}

enum QuestState {
    Active { id: string, count: int },
    #[terminal]
    Done { id: string },
    Streak(kind: string = "weekly", count: int),
}

#[doc("Scored contract")]
trait Scored {
    #[doc("Score reward")]
    fn score(self) -> int;
    fn weighted(self, amount: int, multiplier: int = 2, offset: int = BASE) -> int;
}

impl Scored for Reward {
    fn score(self) -> int {
        return self.count + BASE;
    }

    fn weighted(self, amount: int, multiplier: int = 2, offset: int = BASE) -> int {
        return self.count + amount * multiplier + offset;
    }
}

fn maybe_bonus(flag) {
    if flag {
        return option.some(3);
    }
    return option.none();
}

fn result_bonus(flag) {
    let bonus = maybe_bonus(flag)?;
    return result.ok(bonus + 1);
}

fn add(base, amount = 1, bonus = amount + BASE) {
    return base + amount + bonus;
}

#[doc("Core conformance entry")]
fn main() {
    let reward: Reward = Reward { item: "gold", count: 5 };
    /* Nested comments inside executable bodies must not affect lowering:
       /* let impossible = missing_symbol; */
    */
    #[trace("values")]
    let values: array = [1, 2, 3, 4, 5];
    let total: int = 0;
    #[audit]
    for value in values {
        if value == 2 {
            continue;
        }
        if value > 4 {
            break;
        }
        total += value;
    }
    let compound_score: int = 20;
    compound_score -= 3;
    compound_score *= 2;
    compound_score /= 4;
    compound_score %= 5;
    let logical_score: int = {
        let short_or = if true || (1 / 0 == 0) { 4 } else { 0 };
        let short_and = if false && (1 / 0 == 0) { 0 } else { 6 };
        let negated = -BASE + 5;
        if !false {
            short_or + short_and + negated
        } else {
            0
        }
    };

    let doubled: int = values
        .filter(|value| value % 2 == 1)
        .map(|value| value * 2)
        .sum();

    let quest: QuestState = QuestState.Active { id: "daily", count: 2 };
    let quest_score: int = match quest {
        QuestState.Active { id, count } if id == "daily" => count + 10,
        QuestState.Done { id } => id.len(),
        _ => 0,
    };
    let streak: QuestState = QuestState.Streak(count = 4);
    let streak_score: int = match streak {
        QuestState.Streak(kind, count) if kind == "weekly" => count * 3,
        _ => 0,
    };

    let block_value: int = {
        let local = add(bonus = 3, base = 4);
        local + reward.score()
    };
    let named_method_score: int = reward.weighted(offset = 4, amount = 3);
    let nested_lambda_score: int = {
        let make_nested = |base| {
            return |amount| {
                return |bonus| base + amount + bonus;
            };
        };
        let make = make_nested(8);
        let add = make(4);
        add(2)
    };

    let parsed: int = "42".parse_int().unwrap_or(0);
    let result: int = result_bonus(true)?;
    let mapped: map = {"gold": reward.count, "quest": quest_score}
        .map_values(|key, value| key.len() + value);
    let mutable_rewards: map = {"gold": 1, "xp": 2};
    mutable_rewards.set("quest", 4);
    let removed_reward = mutable_rewards.remove("xp");
    let merged_rewards: map = mutable_rewards.merge({"gold": 5, "gem": 6});
    let map_score: int = option.unwrap_or(removed_reward, 0)
        + mutable_rewards.get_or("missing", 7)
        + merged_rewards["gold"]
        + merged_rewards["gem"]
        + merged_rewards.len();
    let player_tags: set = set.from_array(["daily", "quest", "raid"]);
    let event_tags: set = set.from_array(["quest", "bonus", "daily"]);
    let required_tags: set = set.from_array(["daily", "quest"]);
    let set_score: int = {
        let shared = player_tags.intersection(event_tags);
        let unique = player_tags.difference(event_tags);
        if required_tags.is_subset(player_tags)
            && player_tags.is_superset(required_tags)
            && player_tags.is_disjoint(set.from_array(["bonus"]))
            && player_tags.union(event_tags).len() == 4
            && player_tags.symmetric_difference(event_tags).len() == 2
            && shared.has("quest")
            && unique.has("raid")
        {
            shared.len() + unique.len()
        } else {
            0
        }
    };
    let player: Player = Player {
        stats: Stats {
            level: 2,
            exp: 5,
        },
    };
    player.stats.level += 3;
    player.stats.exp = player.stats.level + 1;
    let nested_score: int = player.stats.level + player.stats.exp;
    let players: array = [
        Player {
            stats: Stats {
                level: 2,
                exp: 0,
            },
        },
        Player {
            stats: Stats {
                level: 5,
                exp: 1,
            },
        },
    ];
    players[0].stats.level += 4;
    players[1].stats.exp = players[0].stats.level + 3;
    let indexed_record_score: int = players[0].stats.level + players[1].stats.exp;
    let no_else_score: int = {
        let maybe = if false {
            9;
        };
        if maybe == null { 6 } else { 0 }
    };
    let imported_reward: ConfigReward = ConfigReward { item: "gem" };
    let imported_bonus: int = reward_bonus(imported_reward.count) + REWARD_BASE;
    let outcome: Outcome = Outcome.Granted {
        item: imported_reward.item,
        count: imported_reward.count,
    };
    let imported_match: int = match outcome {
        Outcome.Granted { item, count } if item == "gem" => count + 5,
        Outcome.Skipped(reason) => reason.len(),
        _ => 0,
    };
    let imported_counts: array = REWARD_COUNTS;
    let imported_table: map = REWARD_TABLE;
    let imported_const_score: int = imported_counts.sum() + imported_table["gem"];

    return total
        + compound_score
        + logical_score
        + doubled
        + quest_score
        + streak_score
        + block_value
        + named_method_score
        + nested_lambda_score
        + parsed
        + result
        + mapped["gold"]
        + mapped["quest"]
        + map_score
        + set_score
        + nested_score
        + indexed_record_score
        + no_else_score
        + imported_bonus
        + imported_match
        + imported_const_score;
}
